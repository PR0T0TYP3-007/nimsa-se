<%- include('layout-top') %>

<div class="admin-header">
  <h1>Edit Executive</h1>
  <p>Update profile information for <%= exec.name %></p>
</div>

<div class="admin-card">
  <div class="admin-card-header">
    <h3>Edit: <%= exec.name %></h3>
    <a href="/admin/executives" class="btn btn-sm btn-outline-gold">← Back</a>
  </div>
  <div class="admin-card-body">
    <form action="/admin/executives/<%= exec._id %>/edit" method="POST" enctype="multipart/form-data">
      <div class="admin-form-grid">
        <div class="form-group">
          <label class="form-label">Full Name *</label>
          <input type="text" name="name" class="form-control" value="<%= exec.name %>" required>
        </div>
        <div class="form-group">
          <label class="form-label">Position *</label>
          <input type="text" name="position" class="form-control" value="<%= exec.position %>" required>
        </div>
        <div class="form-group">
          <label class="form-label">Category *</label>
          <select name="category" class="form-control" required>
            <option value="coordinator" <%= exec.category==='coordinator'?'selected':'' %>>Regional Coordinator (Current)</option>
            <option value="rec" <%= exec.category==='rec'?'selected':'' %>>REC Member</option>
            <option value="school-president" <%= exec.category==='school-president'?'selected':'' %>>MSA President</option>
            <option value="standing-committee" <%= exec.category==='standing-committee'?'selected':'' %>>Standing Committee Rep</option>
            <option value="past-coordinator" <%= exec.category==='past-coordinator'?'selected':'' %>>Past Regional Coordinator</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">School *</label>
          <select name="school" class="form-control" required>
            <option value="">— Select institution —</option>
            <% (institutions||[]).forEach(inst => { %>
              <option value="<%= inst.name %>" <%= exec.school===inst.name?'selected':'' %>><%= inst.acronym %> — <%= inst.name %></option>
            <% }) %>
            <option value="Other" <%= exec.school==='Other'?'selected':'' %>>Other</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">WhatsApp Number</label>
          <input type="text" name="whatsapp" class="form-control" value="<%= exec.whatsapp %>">
        </div>
        <div class="form-group">
          <label class="form-label">Tenure / Year <span style="color:var(--text-muted);font-weight:400;">(for Past Coordinators)</span></label>
          <input type="text" name="tenure" class="form-control" value="<%= exec.tenure || '' %>" placeholder="e.g. 2022/2023">
        </div>
        <div class="form-group">
          <label class="form-label">Email</label>
          <input type="email" name="email" class="form-control" value="<%= exec.email %>">
        </div>
        <div class="form-group">
          <label class="form-label">Photo</label>
          <% if (exec.photo) { %>
          <div style="margin-bottom:0.6rem;">
            <img src="<%= exec.photo %>" alt="Current photo" style="width:70px;height:70px;border-radius:50%;object-fit:cover;border:2px solid var(--gold);">
            <div style="font-size:0.75rem;color:var(--text-muted);margin-top:0.3rem;">Current photo — upload new to replace</div>
          </div>
          <% } %>
          <div class="drop-zone" style="margin-bottom:0.5rem;">
            <div class="drop-zone-icon">📸</div>
            <div class="drop-zone-text">Click or drag new photo here</div>
            <div class="drop-zone-sub">JPG, PNG, WebP — max 5MB</div>
            <input type="file" name="photoFile" accept="image/*">
            <div class="preview-grid"></div>
          </div>
          <input type="url" name="photo" class="form-control" value="<%= exec.photo %>" placeholder="Or paste image URL">
        </div>
        <div class="form-group" style="grid-column:1/-1;">
          <label class="form-label">Bio</label>
          <textarea name="bio" class="form-control" rows="3"><%= exec.bio %></textarea>
        </div>
      </div>
      <div style="display:flex;gap:1rem;">
        <button type="submit" class="btn btn-gold">Save Changes</button>
        <a href="/admin/executives" class="btn btn-outline-gold">Cancel</a>
      </div>
    </form>
  </div>
</div>

<%- include('layout-bottom') %>
