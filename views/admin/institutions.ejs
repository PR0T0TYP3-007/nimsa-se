<%- include('layout-top') %>

<div class="admin-header">
  <h1>Member Schools (MSAs)</h1>
  <p>Manage the 13 member associations of NiMSA South East Region — update names, MDCN quotas, and accreditation status.</p>
</div>

<!-- Add New Institution -->
<div class="admin-card">
  <div class="admin-card-header"><h3>Add New Member School</h3></div>
  <div class="admin-card-body">
    <form action="/admin/institutions" method="POST">
      <div class="admin-form-grid">
        <div class="form-group">
          <label class="form-label">Institution Full Name *</label>
          <input type="text" name="name" class="form-control" placeholder="e.g. University of Nigeria, Enugu" required>
        </div>
        <div class="form-group">
          <label class="form-label">Association Name *</label>
          <input type="text" name="assoc" class="form-control" placeholder="e.g. UNMSA" required>
        </div>
        <div class="form-group">
          <label class="form-label">Acronym *</label>
          <input type="text" name="acronym" class="form-control" placeholder="e.g. UNMSA" required>
        </div>
        <div class="form-group">
          <label class="form-label">State *</label>
          <select name="state" class="form-control" required>
            <option value="">— Select state —</option>
            <option>Abia</option><option>Anambra</option><option>Ebonyi</option>
            <option>Enugu</option><option>Imo</option><option>Imo/Anambra</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">Institution Type *</label>
          <select name="type" class="form-control" required>
            <option>Federal</option><option>State</option><option>Private</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">Accreditation Status *</label>
          <select name="status" class="form-control" required>
            <option>Fully Accredited</option>
            <option>Partially Accredited</option>
            <option>Provisional</option>
            <option>Pending</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">MDCN Medical Quota</label>
          <input type="number" name="quota" class="form-control" placeholder="e.g. 150" min="0" value="0">
        </div>
        <div class="form-group">
          <label class="form-label">MDCN Dental Quota</label>
          <input type="number" name="dental_quota" class="form-control" placeholder="e.g. 15 (0 if none)" min="0" value="0">
        </div>
      </div>
      <button type="submit" class="btn btn-gold">+ Add School</button>
    </form>
  </div>
</div>

<!-- Existing Institutions -->
<div class="admin-card">
  <div class="admin-card-header">
    <h3>All Member Schools (<%= institutions.length %>)</h3>
    <div style="display:flex;gap:0.5rem;">
      <span class="badge badge-blue"><%= institutions.filter(i=>i.type==='Federal').length %> Federal</span>
      <span class="badge badge-green"><%= institutions.filter(i=>i.type==='State').length %> State</span>
      <span class="badge badge-purple"><%= institutions.filter(i=>i.type==='Private').length %> Private</span>
    </div>
  </div>
  <div class="admin-card-body" style="padding:0;">
    <% institutions.forEach((inst, i) => { %>
    <div style="border-bottom:1px solid var(--border);background:<%= i%2===0?'white':'var(--green-pale)' %>;">
      <!-- Main row -->
      <div style="display:flex;flex-wrap:wrap;align-items:center;gap:0.8rem;padding:1rem 1.2rem;">
        <div style="flex:1;min-width:180px;">
          <div style="display:flex;align-items:center;gap:0.5rem;flex-wrap:wrap;margin-bottom:0.25rem;">
            <span style="font-weight:700;font-size:0.9rem;color:var(--green-deep);"><%= inst.acronym %></span>
            <span class="badge <%= inst.type==='Federal'?'badge-blue':inst.type==='Private'?'badge-purple':'badge-green' %>" style="font-size:0.6rem;"><%= inst.type %></span>
            <span class="badge <%= inst.status==='Fully Accredited'?'badge-green':'badge-orange' %>" style="font-size:0.6rem;"><%= inst.status %></span>
          </div>
          <div style="font-size:0.78rem;color:var(--text-body);"><%= inst.name %></div>
          <div style="font-size:0.72rem;color:var(--text-muted);margin-top:0.2rem;">
            📍 <%= inst.state %> &nbsp;·&nbsp;
            🎓 Medical quota: <strong><%= inst.quota || 'N/A' %></strong>
            <% if (inst.dental_quota > 0) { %>&nbsp;·&nbsp; 🦷 Dental: <strong><%= inst.dental_quota %></strong><% } %>
          </div>
        </div>
        <!-- Quick edit toggle -->
        <button class="btn btn-sm btn-outline-gold" onclick="toggleEdit('<%= inst._id %>')">Edit</button>
        <form action="/admin/institutions/<%= inst._id %>/delete" method="POST" style="display:inline;">
          <button type="submit" class="btn btn-sm btn-danger" data-confirm="Remove <%= inst.acronym %> from the region?">Remove</button>
        </form>
      </div>

      <!-- Inline edit form (hidden by default) -->
      <div id="edit-<%= inst._id %>" style="display:none;padding:1rem 1.2rem;background:var(--gold-subtle);border-top:1px solid var(--border-gold);">
        <form action="/admin/institutions/<%= inst._id %>/edit" method="POST">
          <div class="admin-form-grid" style="margin-bottom:0.8rem;">
            <div class="form-group" style="margin-bottom:0.6rem;">
              <label class="form-label">Full Name</label>
              <input type="text" name="name" class="form-control" value="<%= inst.name %>" required>
            </div>
            <div class="form-group" style="margin-bottom:0.6rem;">
              <label class="form-label">Association / Acronym</label>
              <input type="text" name="assoc" class="form-control" value="<%= inst.assoc %>" required>
            </div>
            <div class="form-group" style="margin-bottom:0.6rem;">
              <label class="form-label">State</label>
              <select name="state" class="form-control">
                <% ['Abia','Anambra','Ebonyi','Enugu','Imo','Imo/Anambra'].forEach(s => { %>
                  <option value="<%= s %>" <%= inst.state===s?'selected':'' %>><%= s %></option>
                <% }) %>
              </select>
            </div>
            <div class="form-group" style="margin-bottom:0.6rem;">
              <label class="form-label">Type</label>
              <select name="type" class="form-control">
                <% ['Federal','State','Private'].forEach(t => { %>
                  <option value="<%= t %>" <%= inst.type===t?'selected':'' %>><%= t %></option>
                <% }) %>
              </select>
            </div>
            <div class="form-group" style="margin-bottom:0.6rem;">
              <label class="form-label">Medical Quota</label>
              <input type="number" name="quota" class="form-control" value="<%= inst.quota %>" min="0">
            </div>
            <div class="form-group" style="margin-bottom:0.6rem;">
              <label class="form-label">Dental Quota</label>
              <input type="number" name="dental_quota" class="form-control" value="<%= inst.dental_quota %>" min="0">
            </div>
            <div class="form-group" style="margin-bottom:0.6rem;">
              <label class="form-label">Accreditation Status</label>
              <select name="status" class="form-control">
                <% ['Fully Accredited','Partially Accredited','Provisional','Pending'].forEach(st => { %>
                  <option value="<%= st %>" <%= inst.status===st?'selected':'' %>><%= st %></option>
                <% }) %>
              </select>
            </div>
            <div class="form-group" style="margin-bottom:0.6rem;">
              <label class="form-label">Acronym</label>
              <input type="text" name="acronym" class="form-control" value="<%= inst.acronym %>">
            </div>
          </div>
          <div style="display:flex;gap:0.5rem;">
            <button type="submit" class="btn btn-gold btn-sm">Save Changes</button>
            <button type="button" class="btn btn-sm btn-outline-gold" onclick="toggleEdit('<%= inst._id %>')">Cancel</button>
          </div>
        </form>
      </div>
    </div>
    <% }) %>
    <% if (!institutions.length) { %>
    <div style="padding:2rem;text-align:center;color:var(--text-muted);">No institutions yet. Add one above.</div>
    <% } %>
  </div>
</div>

<!-- Summary Stats -->
<div class="grid-4" style="margin-top:1rem;">
  <div class="stat-card">
    <div class="stat-icon blue"><svg width="22" height="22" fill="currentColor" viewBox="0 0 24 24"><path d="M12 3L1 9l11 6 9-4.91V17h2V9L12 3z"/><path d="M5 13.18v4L12 21l7-3.82v-4L12 17l-7-3.82z"/></svg></div>
    <div><div class="stat-num"><%= institutions.filter(i=>i.type==='Federal').length %></div><div class="stat-label">Federal Schools</div></div>
  </div>
  <div class="stat-card">
    <div class="stat-icon green"><svg width="22" height="22" fill="currentColor" viewBox="0 0 24 24"><path d="M12 3L1 9l11 6 9-4.91V17h2V9L12 3z"/></svg></div>
    <div><div class="stat-num"><%= institutions.filter(i=>i.type==='State').length %></div><div class="stat-label">State Schools</div></div>
  </div>
  <div class="stat-card">
    <div class="stat-icon purple"><svg width="22" height="22" fill="currentColor" viewBox="0 0 24 24"><path d="M12 3L1 9l11 6 9-4.91V17h2V9L12 3z"/></svg></div>
    <div><div class="stat-num"><%= institutions.filter(i=>i.type==='Private').length %></div><div class="stat-label">Private Schools</div></div>
  </div>
  <div class="stat-card">
    <div class="stat-icon gold"><svg width="22" height="22" fill="currentColor" viewBox="0 0 24 24"><path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/></svg></div>
    <div><div class="stat-num"><%= institutions.reduce((sum,i)=>sum+(i.quota||0),0) %></div><div class="stat-label">Total Med. Quota</div></div>
  </div>
</div>

<script>
function toggleEdit(id) {
  const el = document.getElementById('edit-' + id);
  el.style.display = el.style.display === 'none' ? 'block' : 'none';
}
</script>

<%- include('layout-bottom') %>
