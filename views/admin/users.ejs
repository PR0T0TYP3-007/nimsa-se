<%- include('layout-top') %>

<div class="admin-header">
  <h1>Manage Users</h1>
  <p>View all registered users, promote admins, and remove accounts.</p>
</div>

<div class="admin-card">
  <div class="admin-card-header">
    <h3>All Users (<%= users.length %>)</h3>
    <span class="badge badge-gold"><%= users.filter(u=>u.role==='admin').length %> admins</span>
  </div>
  <div class="table-wrapper">
    <table>
      <thead>
        <tr><th>Name</th><th>Email</th><th>Role</th><th>Institution</th><th>Joined</th><th>Actions</th></tr>
      </thead>
      <tbody>
        <% users.forEach(u => { %>
        <tr>
          <td>
            <div style="display:flex;align-items:center;gap:0.7rem;">
              <div style="width:34px;height:34px;border-radius:50%;background:var(--green-light);display:flex;align-items:center;justify-content:center;font-weight:700;font-size:0.75rem;color:var(--green-primary);flex-shrink:0;">
                <%= u.name.charAt(0) %>
              </div>
              <strong><%= u.name %></strong>
              <% if (u.id === user.id) { %><span class="badge badge-green">You</span><% } %>
            </div>
          </td>
          <td><%= u.email %></td>
          <td><span class="badge <%= u.role==='admin'?'badge-gold':'badge-blue' %>"><%= u.role %></span></td>
          <td style="font-size:0.82rem;"><%= u.institution || '—' %></td>
          <td><%= new Date(u.createdAt).toLocaleDateString('en-NG', {day:'numeric',month:'short',year:'numeric'}) %></td>
          <td>
            <% if (u.id !== user.id) { %>
            <div style="display:flex;gap:0.4rem;flex-wrap:wrap;">
              <form action="/admin/users/<%= u.id %>/toggle-admin" method="POST" style="display:inline;">
                <button type="submit" class="btn btn-sm btn-outline-gold" data-confirm="Change role for <%= u.name %>?">
                  <%= u.role==='admin'?'Remove Admin':'Make Admin' %>
                </button>
              </form>
              <form action="/admin/users/<%= u.id %>/delete" method="POST" style="display:inline;">
                <button type="submit" class="btn btn-sm btn-danger" data-confirm="Permanently delete <%= u.name %>?">Delete</button>
              </form>
            </div>
            <% } else { %>
            <span style="font-size:0.8rem;color:var(--text-muted);">Current account</span>
            <% } %>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<div class="info-box">
  <p>⚠️ <strong>Warning:</strong> Deleting a user account is permanent. Promoting a user to admin gives them full access to manage all content on this website.</p>
</div>

<%- include('layout-bottom') %>
