<%- include('layout-top') %>

<div class="admin-header">
  <h1>Manage Users</h1>
  <p>View registered users, promote admins, and remove accounts.</p>
</div>

<div class="admin-card">
  <div class="admin-card-header">
    <h3>All Users (<%= users.length %>)</h3>
    <span class="badge badge-gold"><%= users.filter(u=>u.role==='admin').length %> admin<%= users.filter(u=>u.role==='admin').length!==1?'s':'' %></span>
  </div>
  <div class="admin-card-body" style="padding:0;">
    <% users.forEach((u, i) => { %>
    <div style="display:flex;flex-wrap:wrap;align-items:center;gap:0.8rem;padding:1rem 1.2rem;border-bottom:1px solid var(--border);background:<%= i%2===0?'white':'var(--green-pale)' %>;">
      <!-- Avatar + name -->
      <div style="display:flex;align-items:center;gap:0.7rem;flex:1;min-width:140px;">
        <div style="width:36px;height:36px;border-radius:50%;background:var(--green-light);display:flex;align-items:center;justify-content:center;font-weight:700;font-size:0.8rem;color:var(--green-primary);flex-shrink:0;border:1px solid var(--border);">
          <%= u.name.charAt(0).toUpperCase() %>
        </div>
        <div style="min-width:0;">
          <div style="font-weight:700;font-size:0.88rem;color:var(--green-deep);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
            <%= u.name %>
            <% if (u.id === user.id) { %><span class="badge badge-green" style="margin-left:4px;font-size:0.58rem;">You</span><% } %>
          </div>
          <div style="font-size:0.75rem;color:var(--text-muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:200px;"><%= u.email %></div>
          <% if (u.institution) { %><div style="font-size:0.7rem;color:var(--text-muted);"><%= u.institution %><% if(u.level){%> · <%=u.level%><% } %></div><% } %>
        </div>
      </div>
      <!-- Role + date -->
      <div style="display:flex;align-items:center;gap:0.6rem;flex-shrink:0;">
        <span class="badge <%= u.role==='admin'?'badge-gold':'badge-blue' %>"><%= u.role %></span>
        <span style="font-size:0.7rem;color:var(--text-muted);white-space:nowrap;"><%= new Date(u.createdAt).toLocaleDateString('en-NG',{day:'numeric',month:'short',year:'numeric'}) %></span>
      </div>
      <!-- Actions -->
      <% if (u.id !== user.id) { %>
      <div style="display:flex;gap:0.4rem;flex-shrink:0;flex-wrap:wrap;">
        <form action="/admin/users/<%= u.id %>/toggle-admin" method="POST" style="display:inline;">
          <button type="submit" class="btn btn-sm btn-outline-gold" data-confirm="Change role for <%= u.name %>?">
            <%= u.role==='admin'?'Remove Admin':'Make Admin' %>
          </button>
        </form>
        <form action="/admin/users/<%= u.id %>/delete" method="POST" style="display:inline;">
          <button type="submit" class="btn btn-sm btn-danger" data-confirm="Permanently delete <%= u.name %>?">Delete</button>
        </form>
      </div>
      <% } else { %>
      <span style="font-size:0.75rem;color:var(--text-muted);font-style:italic;flex-shrink:0;">Current account</span>
      <% } %>
    </div>
    <% }) %>
  </div>
</div>

<div class="info-box">
  <p>⚠️ <strong>Warning:</strong> Deleting a user is permanent. Promoting to admin gives full access to manage all site content.</p>
</div>

<%- include('layout-bottom') %>
