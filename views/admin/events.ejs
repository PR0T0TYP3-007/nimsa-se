<%- include('layout-top') %>

<div class="admin-header">
  <h1>Manage Events</h1>
  <p>Create and manage webinars, conventions, campaigns, and other events.</p>
</div>

<!-- Add Event Form -->
<div class="admin-card">
  <div class="admin-card-header"><h3>Add New Event</h3></div>
  <div class="admin-card-body">
    <form action="/admin/events" method="POST" enctype="multipart/form-data">
      <div class="admin-form-grid">
        <div class="form-group" style="grid-column:1/-1;">
          <label class="form-label">Event Title *</label>
          <input type="text" name="title" class="form-control" placeholder="e.g. Clinical Skills Webinar — Cardiology" required>
        </div>
        <div class="form-group">
          <label class="form-label">Date *</label>
          <input type="date" name="date" class="form-control" required>
        </div>
        <div class="form-group">
          <label class="form-label">Time *</label>
          <input type="time" name="time" class="form-control" required>
        </div>
        <div class="form-group">
          <label class="form-label">Event Type *</label>
          <select name="type" class="form-control" required>
            <option>Webinar</option>
            <option>Convention</option>
            <option>Workshop</option>
            <option>Campaign</option>
            <option>Seminar</option>
            <option>Summit</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">Location *</label>
          <input type="text" name="location" class="form-control" placeholder="e.g. Online (Zoom) or University of Nigeria, Nsukka" required>
        </div>
        <div class="form-group">
          <label class="form-label">Event Image</label>
          <div class="drop-zone" style="margin-bottom:0.5rem;">
            <div class="drop-zone-icon">🖼️</div>
            <div class="drop-zone-text">Click or drag image here</div>
            <div class="drop-zone-sub">JPG, PNG, WebP — max 5MB</div>
            <input type="file" name="imageFile" accept="image/*">
            <div class="preview-grid"></div>
          </div>
          <input type="url" name="image" class="form-control" placeholder="Or paste image URL (optional)">
        </div>
        <div class="form-group">
          <label class="form-label">Registration Link</label>
          <input type="url" name="registrationLink" class="form-control" placeholder="https://...">
        </div>
        <div class="form-group" style="grid-column:1/-1;">
          <label class="form-label">Description *</label>
          <textarea name="description" class="form-control" rows="4" placeholder="Full event description..." required></textarea>
        </div>
      </div>
      <button type="submit" class="btn btn-gold">+ Add Event</button>
    </form>
  </div>
</div>

<!-- Events Table -->
<div class="admin-card">
  <div class="admin-card-header">
    <h3>All Events (<%= events.length %>)</h3>
  </div>
  <div class="admin-card-body" style="padding:0;">
    <% events.sort((a,b)=>new Date(b.date)-new Date(a.date)).forEach((ev,i) => { %>
    <div style="display:flex;flex-wrap:wrap;align-items:center;gap:0.8rem;padding:1rem 1.2rem;border-bottom:1px solid var(--border);background:<%= i%2===0?'white':'var(--green-pale)' %>;">
      <div style="flex:1;min-width:160px;">
        <div style="font-weight:700;font-size:0.88rem;color:var(--green-deep);margin-bottom:0.2rem;"><%= ev.title %></div>
        <div style="font-size:0.75rem;color:var(--text-muted);">📅 <%= new Date(ev.date).toLocaleDateString('en-NG',{day:'numeric',month:'short',year:'numeric'}) %> · 📍 <%= ev.location %></div>
      </div>
      <div style="display:flex;align-items:center;gap:0.5rem;flex-shrink:0;flex-wrap:wrap;">
        <span class="badge badge-green"><%= ev.type %></span>
        <span class="badge <%= ev.status==='upcoming'?'badge-gold':'badge-blue' %>"><%= ev.status %></span>
        <form action="/admin/events/<%= ev._id %>/delete" method="POST" style="display:inline;">
          <button type="submit" class="btn btn-sm btn-danger" data-confirm="Delete this event?">Delete</button>
        </form>
      </div>
    </div>
    <% }) %>
    <% if (!events.length) { %>
    <div style="padding:2rem;text-align:center;color:var(--text-muted);font-size:0.88rem;">No events yet. Add one above.</div>
    <% } %>
  </div>
</div>

<%- include('layout-bottom') %>
