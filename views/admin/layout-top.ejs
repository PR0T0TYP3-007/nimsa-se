<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="admin-body">

<!-- ── ADMIN TOP BAR (mobile + desktop) ── -->
<header class="admin-topbar">
  <div class="admin-topbar-left">
    <!-- Hamburger to toggle sidebar -->
    <button class="admin-hamburger" id="adminHamburger" aria-label="Toggle sidebar">
      <span></span><span></span><span></span>
    </button>
    <a href="/" class="admin-topbar-logo">
      <img src="/logo.jpg" alt="NiMSA SE" class="admin-topbar-logo-img">
      <div>
        <div class="admin-topbar-logo-name">NiMSA SE</div>
        <div class="admin-topbar-logo-sub">Admin Panel</div>
      </div>
    </a>
  </div>
  <div class="admin-topbar-right">
    <span class="admin-topbar-user">
      <svg width="15" height="15" fill="currentColor" viewBox="0 0 24 24"><path d="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z"/></svg>
      <%= user.name.split(' ')[0] %>
    </span>
    <a href="/" class="btn btn-outline-gold btn-sm" style="font-size:0.72rem;padding:0.28rem 0.7rem;">View Site</a>
    <a href="/auth/logout" class="btn btn-sm" style="background:rgba(229,115,115,0.15);color:#ef9a9a;border-color:rgba(229,115,115,0.3);font-size:0.72rem;padding:0.28rem 0.7rem;">Logout</a>
  </div>
</header>

<!-- ── SIDEBAR OVERLAY (mobile only) ── -->
<div class="admin-sidebar-overlay" id="adminOverlay"></div>

<div class="admin-layout">
  <!-- ── SIDEBAR ── -->
  <aside class="admin-sidebar" id="adminSidebar">
    <div class="admin-sidebar-header">
      <div style="display:flex;align-items:center;justify-content:space-between;">
        <div>
          <div class="admin-sidebar-title">Admin Dashboard</div>
          <div class="admin-sidebar-sub">NiMSA SE — ICT Directorate</div>
        </div>
        <!-- Close button — mobile only -->
        <button class="admin-sidebar-close" id="adminSidebarClose" aria-label="Close sidebar">✕</button>
      </div>
    </div>
    <nav>
      <a href="/admin" class="admin-nav-item">
        <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M3 13h8V3H3v10zm0 8h8v-6H3v6zm10 0h8V11h-8v10zm0-18v6h8V3h-8z"/></svg>
        Dashboard
      </a>
      <a href="/admin/executives" class="admin-nav-item">
        <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/></svg>
        Executives
      </a>
      <a href="/admin/events" class="admin-nav-item">
        <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M17 12h-5v5h5v-5zM16 1v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2h-1V1h-2zm3 18H5V8h14v11z"/></svg>
        Events
      </a>
      <a href="/admin/bulletin" class="admin-nav-item">
        <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M14 2H6c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V8l-6-6zM6 20V4h7v5h5v11H6z"/></svg>
        Bulletins
      </a>
      <a href="/admin/news" class="admin-nav-item">
        <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M20 3H4v10c0 2.21 1.79 4 4 4h6c2.21 0 4-1.79 4-4v-3h2c1.11 0 2-.89 2-2V5c0-1.11-.89-2-2-2zm0 5h-2V5h2v3zM4 19h16v2H4z"/></svg>
        News
      </a>
      <a href="/admin/institutions" class="admin-nav-item">
        <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M12 3L1 9l11 6 9-4.91V17h2V9L12 3zM5 13.18v4L12 21l7-3.82v-4L12 17l-7-3.82z"/></svg>
        Member Schools
      </a>
      <a href="/admin/users" class="admin-nav-item">
        <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>
        Users
      </a>
      <a href="/admin/settings" class="admin-nav-item">
        <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.07-.94l2.03-1.58c.18-.14.23-.41.12-.61l-1.92-3.32c-.12-.22-.37-.29-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54c-.04-.24-.24-.41-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.09.63-.09.94s.02.64.07.94l-2.03 1.58c-.18.14-.23.41-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z"/></svg>
        Settings
      </a>
      <div style="border-top:1px solid rgba(255,255,255,0.08);margin-top:1rem;padding-top:1rem;">
        <a href="/admin/change-password" class="admin-nav-item">
          <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z"/></svg>
          Change Password
        </a>
        <a href="/" class="admin-nav-item">
          <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/></svg>
          View Website
        </a>
        <a href="/auth/logout" class="admin-nav-item" style="color:#ef9a9a;">
          <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M17 7l-1.41 1.41L18.17 11H8v2h10.17l-2.58 2.58L17 17l5-5zM4 5h8V3H4c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h8v-2H4V5z"/></svg>
          Logout
        </a>
      </div>
    </nav>
  </aside>

  <!-- ── MAIN CONTENT ── -->
  <main class="admin-main">
    <% if (typeof success !== 'undefined' && success.length) { %>
    <div class="alert alert-success">✓ <%= success[0] %></div>
    <% } %>
    <% if (typeof error !== 'undefined' && error.length) { %>
    <div class="alert alert-error">✗ <%= error[0] %></div>
    <% } %>
