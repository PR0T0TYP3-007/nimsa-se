<%- include('layout-top') %>

<div class="admin-header">
  <h1>Manage News</h1>
  <p>Post announcements, outreach reports, and success stories.</p>
</div>

<div class="admin-card">
  <div class="admin-card-header"><h3>Add News Post</h3></div>
  <div class="admin-card-body">
    <form action="/admin/news" method="POST" enctype="multipart/form-data">
      <div class="admin-form-grid">
        <div class="form-group" style="grid-column:1/-1;">
          <label class="form-label">Title *</label>
          <input type="text" name="title" class="form-control" placeholder="News headline..." required>
        </div>
        <div class="form-group">
          <label class="form-label">Category *</label>
          <select name="category" class="form-control" required>
            <option>Achievement</option>
            <option>Outreach</option>
            <option>Programs</option>
            <option>Announcement</option>
            <option>Award</option>
            <option>Partnership</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">Date *</label>
          <input type="date" name="date" class="form-control" value="<%= new Date().toISOString().split('T')[0] %>" required>
        </div>
        <div class="form-group" style="grid-column:1/-1;">
          <label class="form-label">Excerpt (1–2 sentences) *</label>
          <textarea name="excerpt" class="form-control" rows="2" required></textarea>
        </div>
        <div class="form-group" style="grid-column:1/-1;">
          <label class="form-label">Full Content</label>
          <textarea name="content" class="form-control" rows="5" placeholder="Full article content..."></textarea>
        </div>
        <div class="form-group">
          <label class="form-label">Article Image</label>
          <div class="drop-zone" style="margin-bottom:0.5rem;">
            <div class="drop-zone-icon">🖼️</div>
            <div class="drop-zone-text">Click or drag image here</div>
            <div class="drop-zone-sub">JPG, PNG, WebP — max 5MB (optional)</div>
            <input type="file" name="imageFile" accept="image/*">
            <div class="preview-grid"></div>
          </div>
          <input type="url" name="image" class="form-control" placeholder="Or paste image URL (optional)">
        </div>
        <div class="form-group" style="display:flex;align-items:center;">
          <label class="form-check">
            <input type="checkbox" name="featured" value="on">
            <span>Set as <strong>featured</strong> post</span>
          </label>
        </div>
      </div>
      <button type="submit" class="btn btn-gold">+ Publish Post</button>
    </form>
  </div>
</div>

<div class="admin-card">
  <div class="admin-card-header"><h3>All News Posts (<%= news.length %>)</h3></div>
  <div class="admin-card-body" style="padding:0;">
    <% news.forEach((n,i) => { %>
    <div style="display:flex;flex-wrap:wrap;align-items:center;gap:0.8rem;padding:1rem 1.2rem;border-bottom:1px solid var(--border);background:<%= i%2===0?'white':'var(--green-pale)' %>;">
      <div style="flex:1;min-width:160px;">
        <div style="font-weight:700;font-size:0.88rem;color:var(--green-deep);margin-bottom:0.2rem;"><%= n.title %></div>
        <div style="font-size:0.75rem;color:var(--text-muted);">📅 <%= new Date(n.date).toLocaleDateString('en-NG',{day:'numeric',month:'short',year:'numeric'}) %></div>
      </div>
      <div style="display:flex;align-items:center;gap:0.5rem;flex-shrink:0;flex-wrap:wrap;">
        <span class="badge badge-green"><%= n.category %></span>
        <span class="badge <%= n.featured?'badge-gold':'badge-blue' %>"><%= n.featured?'Featured':'Published' %></span>
        <form action="/admin/news/<%= n._id %>/delete" method="POST" style="display:inline;">
          <button type="submit" class="btn btn-sm btn-danger" data-confirm="Delete this post?">Delete</button>
        </form>
      </div>
    </div>
    <% }) %>
    <% if (!news.length) { %>
    <div style="padding:2rem;text-align:center;color:var(--text-muted);font-size:0.88rem;">No posts yet. Add one above.</div>
    <% } %>
  </div>
</div>

<%- include('layout-bottom') %>
