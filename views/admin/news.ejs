<%- include('layout-top') %>

<div class="admin-header">
  <h1>Manage News</h1>
  <p>Post announcements, outreach reports, and success stories.</p>
</div>

<div class="admin-card">
  <div class="admin-card-header"><h3>Add News Post</h3></div>
  <div class="admin-card-body">
    <form action="/admin/news" method="POST">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
        <div class="form-group" style="grid-column:1/-1;">
          <label class="form-label">Title *</label>
          <input type="text" name="title" class="form-control" placeholder="News headline..." required>
        </div>
        <div class="form-group">
          <label class="form-label">Category *</label>
          <select name="category" class="form-control" required>
            <option>Achievement</option>
            <option>Outreach</option>
            <option>Programs</option>
            <option>Announcement</option>
            <option>Award</option>
            <option>Partnership</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">Date *</label>
          <input type="date" name="date" class="form-control" value="<%= new Date().toISOString().split('T')[0] %>" required>
        </div>
        <div class="form-group" style="grid-column:1/-1;">
          <label class="form-label">Excerpt (1–2 sentences) *</label>
          <textarea name="excerpt" class="form-control" rows="2" required></textarea>
        </div>
        <div class="form-group" style="grid-column:1/-1;">
          <label class="form-label">Full Content</label>
          <textarea name="content" class="form-control" rows="5" placeholder="Full article content..."></textarea>
        </div>
        <div class="form-group">
          <label class="form-label">Image URL</label>
          <input type="url" name="image" class="form-control" placeholder="https://...">
        </div>
        <div class="form-group" style="display:flex;align-items:center;">
          <label class="form-check">
            <input type="checkbox" name="featured" value="on">
            <span>Set as <strong>featured</strong> post</span>
          </label>
        </div>
      </div>
      <button type="submit" class="btn btn-gold">+ Publish Post</button>
    </form>
  </div>
</div>

<div class="admin-card">
  <div class="admin-card-header"><h3>All News Posts (<%= news.length %>)</h3></div>
  <div class="table-wrapper">
    <table>
      <thead>
        <tr><th>Title</th><th>Category</th><th>Date</th><th>Status</th><th>Actions</th></tr>
      </thead>
      <tbody>
        <% news.forEach(n => { %>
        <tr>
          <td><strong><%= n.title %></strong></td>
          <td><span class="badge badge-green"><%= n.category %></span></td>
          <td><%= new Date(n.date).toLocaleDateString('en-NG', {day:'numeric',month:'short',year:'numeric'}) %></td>
          <td><span class="badge <%= n.featured?'badge-gold':'badge-blue' %>"><%= n.featured?'Featured':'Published' %></span></td>
          <td>
            <form action="/admin/news/<%= n.id %>/delete" method="POST" style="display:inline;">
              <button type="submit" class="btn btn-sm btn-danger" data-confirm="Delete this news post?">Delete</button>
            </form>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<%- include('layout-bottom') %>
