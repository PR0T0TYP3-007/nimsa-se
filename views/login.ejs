<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="auth-page">
  <div class="auth-card">
    <div class="auth-logo">
      <div class="logo-circle-lg"><img src="/logo.jpg" alt="NiMSA SE Logo" style="width:100%;height:100%;object-fit:cover;border-radius:50%;"></div>
      <h1 class="auth-title">Welcome Back</h1>
      <p class="auth-subtitle">Sign in to your NiMSA SE account</p>
    </div>

    <% if (error.length) { %><div class="alert alert-error">✗ <%= error[0] %></div><% } %>
    <% if (success.length) { %><div class="alert alert-success">✓ <%= success[0] %></div><% } %>

    <form action="/auth/login" method="POST" data-validate>
      <div class="form-group">
        <label class="form-label">Email Address</label>
        <input type="email" name="email" class="form-control" placeholder="your@email.com" required autocomplete="email">
      </div>
      <div class="form-group">
        <label class="form-label">Password</label>
        <input type="password" name="password" class="form-control" placeholder="••••••••" required autocomplete="current-password">
      </div>
      <button type="submit" class="btn btn-green btn-block" style="margin-top:0.5rem;justify-content:center;">Sign In</button>
    </form>

    <div class="divider"></div>

    <div class="info-box" style="font-size:0.82rem;">
      <p>🔑 <strong>Default Admin:</strong> admin@nimsase.org / <code>password</code><br>
      Change this immediately in production!</p>
    </div>

    <p class="auth-footer">
      Don't have an account? <a href="/auth/register">Create one</a>
    </p>
    <p class="auth-footer" style="margin-top:0.5rem;">
      <a href="/" style="color:var(--text-muted);">← Back to website</a>
    </p>
  </div>
</div>
<script src="/js/main.js"></script>
</body>
</html>
