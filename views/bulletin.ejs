<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<%- include('partials/nav') %>

<div class="page-hero">
  <div class="container">
    <div class="eyebrow">Monthly Bulletin</div>
    <h1>The Pulse</h1>
    <p>NiMSA South East Region's official monthly newsletter — your connection to regional news, events, and opportunities.</p>
  </div>
</div>

<section class="section">
  <div class="container">
    <% if (success.length) { %><div class="alert alert-success">✓ <%= success[0] %></div><% } %>

    <!-- Featured Bulletin -->
    <% if (featured) { %>
    <div class="bulletin-featured fade-in" style="margin-bottom:4rem;">
      <div>
        <span class="issue-badge"><%= featured.issue %> — Latest Issue</span>
        <h2 style="color:white;margin:1rem 0 0.8rem;"><%= featured.title %></h2>
        <p class="subtitle" style="margin-bottom:1.5rem;"><%= featured.summary %></p>
        <h4 style="color:var(--gold);margin-bottom:1rem;font-size:0.9rem;font-family:var(--font-body);text-transform:uppercase;letter-spacing:0.1em;">In This Issue</h4>
        <div class="bulletin-toc">
          <div class="bulletin-toc-item">Regional Coordinator's Message</div>
          <div class="bulletin-toc-item">Upcoming Events & Programs</div>
          <div class="bulletin-toc-item">Member School News</div>
          <div class="bulletin-toc-item">Academic Resources & Scholarships</div>
          <div class="bulletin-toc-item">Health Outreach Reports</div>
          <div class="bulletin-toc-item">Student Spotlights & Achievements</div>
        </div>
        <div style="display:flex;gap:1rem;flex-wrap:wrap;margin-top:1.5rem;">
          <a href="<%= featured.pdfUrl %>" class="btn btn-gold" target="_blank">📥 Download PDF</a>
          <a href="<%= featured.pdfUrl %>" class="btn btn-outline" style="color:white;border-color:rgba(255,255,255,0.4);" target="_blank">👁 Read Online</a>
        </div>
      </div>
      <div class="bulletin-featured-cover">
        <div style="font-size:0.75rem;color:var(--gold);font-weight:700;letter-spacing:0.12em;text-transform:uppercase;">NiMSA SE</div>
        <div style="font-size:0.75rem;color:rgba(255,255,255,0.6);margin-bottom:1rem;">THE PULSE</div>
        <div style="font-family:var(--font-display);font-size:3rem;font-weight:800;color:white;line-height:1;"><%= featured.month.substring(0,3).toUpperCase() %></div>
        <div style="font-size:1.2rem;color:rgba(255,255,255,0.7);"><%= featured.year %></div>
        <div style="margin-top:1.5rem;padding:1rem;background:rgba(255,255,255,0.05);border-radius:8px;border:1px solid rgba(212,175,55,0.3);">
          <div style="font-size:0.75rem;color:rgba(255,255,255,0.5);">Issue</div>
          <div style="font-size:0.9rem;color:white;font-weight:600;"><%= featured.issue %></div>
        </div>
        <div style="margin-top:1rem;font-size:0.75rem;color:rgba(255,255,255,0.4);">South East Region • ICT Directorate</div>
      </div>
    </div>
    <% } %>

    <!-- Archive -->
    <% if (archive.length) { %>
    <div class="section-header" style="margin-bottom:2rem;">
      <div class="eyebrow">Past Issues</div>
      <h2>Bulletin Archive</h2>
      <div class="gold-line"></div>
    </div>

    <!-- Search -->
    <div style="max-width:400px; margin:0 auto 2rem;">
      <input type="text" id="bulletin-search" class="form-control" placeholder="🔍 Search bulletins by month or year...">
    </div>

    <div class="grid-4">
      <% archive.forEach((b, i) => { %>
      <div class="bulletin-archive-item bulletin-card fade-in" style="transition-delay:<%= i*0.05 %>s">
        <div class="bulletin-cover">
          <% if (b.coverImage) { %>
            <img src="<%= b.coverImage %>" alt="<%= b.title %>" style="width:100%;height:100%;object-fit:cover;">
          <% } else { %>
          <div class="bulletin-cover-inner">
            <div class="issue"><%= b.issue %></div>
            <div class="month"><%= b.month.substring(0,3).toUpperCase() %></div>
            <div class="year"><%= b.year %></div>
          </div>
          <% } %>
        </div>
        <div class="bulletin-body">
          <div class="bulletin-title"><%= b.title %></div>
          <p class="bulletin-summary"><%= b.summary?.substring(0,80) %>...</p>
          <div class="bulletin-actions">
            <a href="<%= b.pdfUrl %>" class="btn btn-sm btn-gold" target="_blank">📥 Download</a>
            <a href="<%= b.pdfUrl %>" class="btn btn-sm btn-outline-gold" target="_blank">Read</a>
          </div>
        </div>
      </div>
      <% }) %>
    </div>
    <% } %>

    <% if (isAdmin) { %>
    <div class="info-box" style="margin-top:3rem;">
      <p>🔧 <strong>Admin:</strong> <a href="/admin/bulletin">Manage bulletins</a> — upload new issues and manage the archive.</p>
    </div>
    <% } %>

    <!-- Newsletter Signup -->
    <div style="background:var(--green-pale);border-radius:var(--radius-lg);padding:3rem;text-align:center;margin-top:4rem;border:1px solid var(--border);">
      <div class="eyebrow" style="display:inline-block;background:var(--gold-light);color:var(--gold-dark);font-size:0.78rem;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;padding:0.3rem 1rem;border-radius:100px;margin-bottom:0.8rem;">Stay Connected</div>
      <h3 style="margin-bottom:0.8rem;">Get The Pulse in Your Inbox</h3>
      <p style="color:var(--text-muted);max-width:400px;margin:0 auto 1.5rem;">Subscribe to receive the NiMSA SE monthly bulletin directly in your email.</p>
      <form action="https://formspree.io/f/your-form-id" method="POST" style="display:flex;gap:0.8rem;max-width:400px;margin:0 auto;flex-wrap:wrap;">
        <input type="email" name="email" placeholder="your@email.com" class="form-control" style="flex:1;min-width:200px;" required>
        <button type="submit" class="btn btn-gold">Subscribe</button>
      </form>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
<script src="/js/main.js"></script>
</body>
</html>
