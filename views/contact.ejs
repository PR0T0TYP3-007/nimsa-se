<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<%- include('partials/nav') %>

<div class="page-hero">
  <div class="container">
    <div class="eyebrow">Get In Touch</div>
    <h1>Contact NiMSA SE</h1>
    <p>Have a question, partnership offer, or want to collaborate? We'd love to hear from you.</p>
  </div>
</div>

<section class="section">
  <div class="container">
    <div class="contact-grid">
      <!-- Form -->
      <div>
        <h2 style="margin-bottom:1.5rem;">Send Us a Message</h2>
        <% if (success.length) { %><div class="alert alert-success">✓ <%= success[0] %></div><% } %>
        <% if (error.length) { %><div class="alert alert-error">✗ <%= error[0] %></div><% } %>
        <form action="https://formspree.io/f/xvzwjpqd" method="POST" data-validate class="card" style="padding:2rem;">
          <input type="hidden" name="form-type" value="Contact">
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
            <div class="form-group">
              <label class="form-label">Your Name *</label>
              <input type="text" name="name" class="form-control" placeholder="Full name" required>
            </div>
            <div class="form-group">
              <label class="form-label">Email Address *</label>
              <input type="email" name="email" class="form-control" placeholder="your@email.com" required>
            </div>
          </div>
          <div class="form-group">
            <label class="form-label">Subject *</label>
            <select name="subject" class="form-control" required>
              <option value="">— Select a subject —</option>
              <option>General Inquiry</option>
              <option>Partnership / Sponsorship</option>
              <option>Event Collaboration</option>
              <option>Media / Press</option>
              <option>Student Welfare</option>
              <option>Career Opportunity Submission</option>
              <option>Other</option>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label">Message *</label>
            <textarea name="message" class="form-control" placeholder="How can we help you?" required style="min-height:150px;"></textarea>
          </div>
          <button type="submit" class="btn btn-green btn-lg" style="width:100%;justify-content:center;">Send Message</button>
        </form>
      </div>

      <!-- Contact Info -->
      <div>
        <h2 style="margin-bottom:1.5rem;">Direct Contact</h2>
        <div class="contact-detail">
          <div class="contact-icon">
            <svg width="22" height="22" fill="white" viewBox="0 0 24 24"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
          </div>
          <div>
            <div style="font-weight:700;font-size:0.9rem;color:var(--green-deep);margin-bottom:0.2rem;">Official Email</div>
            <a href="mailto:<%= settings.email %>" style="color:var(--green-primary);font-size:0.9rem;"><%= settings.email %></a>
          </div>
        </div>
        <div class="contact-detail">
          <div class="contact-icon whatsapp">
            <svg width="22" height="22" fill="white" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          </div>
          <div>
            <div style="font-weight:700;font-size:0.9rem;color:var(--green-deep);margin-bottom:0.2rem;">WhatsApp</div>
            <a href="https://wa.me/<%= settings.whatsappNumber %>" style="color:#25D366;font-size:0.9rem;" target="_blank">Chat with us on WhatsApp →</a>
          </div>
        </div>

        <h3 style="margin:2rem 0 1rem;font-size:1rem;">Follow Us</h3>
        <div style="display:flex;gap:0.8rem;flex-wrap:wrap;">
          <a href="<%= settings.facebook %>" class="btn btn-sm" style="background:#1877f2;color:white;border-color:#1877f2;" target="_blank">Facebook</a>
          <a href="<%= settings.instagram %>" class="btn btn-sm" style="background:linear-gradient(45deg,#f09433,#e6683c,#dc2743,#cc2366,#bc1888);color:white;border:none;" target="_blank">Instagram</a>
          <a href="<%= settings.twitter %>" class="btn btn-sm" style="background:#000;color:white;border-color:#000;" target="_blank">X / Twitter</a>
          <a href="<%= settings.youtube %>" class="btn btn-sm" style="background:#ff0000;color:white;border-color:#ff0000;" target="_blank">YouTube</a>
        </div>

        <div style="background:var(--green-pale);border-radius:var(--radius);padding:1.5rem;margin-top:2rem;border:1px solid var(--border);">
          <h4 style="font-size:0.9rem;margin-bottom:1rem;">ICT Directorate</h4>
          <p style="font-size:0.83rem;color:var(--text-muted);">For technical issues, website feedback, or digital partnership enquiries, contact the ICT Directorate directly.</p>
          <a href="mailto:ict@nimsase.org" style="font-size:0.83rem;color:var(--green-primary);font-weight:600;display:block;margin-top:0.6rem;">ict@nimsase.org →</a>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
<script src="/js/main.js"></script>
</body>
</html>
