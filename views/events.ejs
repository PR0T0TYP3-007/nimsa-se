<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<%- include('partials/nav') %>

<div class="page-hero">
  <div class="container">
    <div class="eyebrow">Events & Programs</div>
    <h1>What We're Up To</h1>
    <p>Webinars, conventions, campaigns, workshops — find and register for events shaping Southeast medical education.</p>
  </div>
</div>

<section class="section">
  <div class="container">
    <% if (success.length) { %><div class="alert alert-success">✓ <%= success[0] %></div><% } %>

    <!-- Filter Tabs -->
    <div class="tabs" id="event-filter" style="max-width:700px; margin: 0 auto 3rem;">
      <button class="tab-btn active" data-type="all">All Events</button>
      <button class="tab-btn" data-type="Webinar">Webinars</button>
      <button class="tab-btn" data-type="Convention">Conventions</button>
      <button class="tab-btn" data-type="Workshop">Workshops</button>
      <button class="tab-btn" data-type="Campaign">Campaigns</button>
    </div>

    <% const upcoming = events.filter(e => e.status === 'upcoming'); %>
    <% const past = events.filter(e => e.status === 'past'); %>

    <% if (upcoming.length) { %>
    <h3 style="margin-bottom:1.5rem; color:var(--green-deep);">Upcoming Events</h3>
    <div class="grid-3" style="margin-bottom:4rem;">
      <% upcoming.forEach(event => { %>
      <div class="event-item" data-type="<%= event.type %>" style="display:block;">
        <div class="event-card">
          <div class="event-img">
            <span class="event-type-badge"><%= event.type %></span>
            <span class="event-date-badge"><%= new Date(event.date).toLocaleDateString('en-NG', {day:'numeric',month:'short'}) %></span>
            <svg width="48" height="48" fill="rgba(255,255,255,0.2)" viewBox="0 0 24 24"><path d="M17 12h-5v5h5v-5zM16 1v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2h-1V1h-2zm3 18H5V8h14v11z"/></svg>
          </div>
          <div class="event-body">
            <div class="event-title"><%= event.title %></div>
            <div class="event-meta">
              <span>📅 <%= new Date(event.date).toLocaleDateString('en-NG', {weekday:'short',day:'numeric',month:'long',year:'numeric'}) %></span>
              <span>🕐 <%= event.time %></span>
              <span>📍 <%= event.location %></span>
            </div>
            <p class="event-desc"><%= event.description %></p>
          </div>
          <div class="event-footer">
            <a href="<%= event.registrationLink %>" class="btn btn-gold btn-sm" style="width:100%;justify-content:center;" target="_blank">Register for Event</a>
          </div>
        </div>
      </div>
      <% }) %>
    </div>
    <% } %>

    <% if (past.length) { %>
    <h3 style="margin-bottom:1.5rem; color:var(--green-deep);">Past Events</h3>
    <div class="grid-3">
      <% past.forEach(event => { %>
      <div class="event-item" data-type="<%= event.type %>" style="display:block;">
        <div class="event-card" style="opacity:0.85;">
          <div class="event-img" style="background:linear-gradient(135deg,#666,#444);">
            <span class="event-type-badge"><%= event.type %></span>
            <span class="event-date-badge"><%= new Date(event.date).toLocaleDateString('en-NG', {day:'numeric',month:'short',year:'numeric'}) %></span>
          </div>
          <div class="event-body">
            <div class="event-title"><%= event.title %></div>
            <div class="event-meta">
              <span>📍 <%= event.location %></span>
            </div>
            <p class="event-desc"><%= event.description.substring(0,100) %>...</p>
          </div>
        </div>
      </div>
      <% }) %>
    </div>
    <% } %>

    <% if (!events.length) { %>
    <div style="text-align:center;padding:4rem 0;color:var(--text-muted);">
      <svg width="64" height="64" fill="var(--green-light)" viewBox="0 0 24 24" style="margin:0 auto 1rem;"><path d="M17 12h-5v5h5v-5zM16 1v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2h-1V1h-2zm3 18H5V8h14v11z"/></svg>
      <h3 style="color:var(--text-muted);">No events yet</h3>
      <p>Check back soon for upcoming events.</p>
    </div>
    <% } %>

    <% if (isAdmin) { %>
    <div class="info-box" style="margin-top:3rem;">
      <p>🔧 <strong>Admin:</strong> <a href="/admin/events">Manage events</a> — add new webinars, conventions, campaigns, and more.</p>
    </div>
    <% } %>
  </div>
</section>

<%- include('partials/footer') %>
<script src="/js/main.js"></script>
</body>
</html>
