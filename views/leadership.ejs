<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<%- include('partials/nav') %>

<div class="page-hero">
  <div class="container">
    <div class="eyebrow">Our Leadership</div>
    <h1>Regional Executive Council</h1>
    <p>Meet the leaders coordinating and governing the NiMSA South East Region — elected to serve over 2,400 medical students.</p>
  </div>
</div>

<section class="section">
  <div class="container">
    <% if (success.length) { %><div class="alert alert-success">✓ <%= success[0] %></div><% } %>

    <!-- Filter Tabs -->
    <div class="tabs" id="exec-filter" style="max-width:600px; margin: 0 auto 3rem;">
      <button class="tab-btn active" data-cat="all">All Leaders</button>
      <button class="tab-btn" data-cat="coordinator">Coordinator</button>
      <button class="tab-btn" data-cat="rec">REC Members</button>
      <button class="tab-btn" data-cat="school-president">School Presidents</button>
    </div>

    <!-- Executives Grid -->
    <div class="grid-3" id="exec-grid">
      <% executives.forEach(exec => { %>
      <div class="exec-card-wrap" data-category="<%= exec.category %>">
        <div class="exec-card">
          <% if (exec.photo) { %>
            <img src="<%= exec.photo %>" alt="<%= exec.name %>" class="exec-photo" style="width:90px;height:90px;object-fit:cover;border-radius:50%;">
          <% } else { %>
            <div class="exec-photo"><%= exec.name.charAt(0) %><%= exec.name.split(' ')[1]?.charAt(0) || '' %></div>
          <% } %>
          <div class="exec-name"><%= exec.name %></div>
          <div class="exec-position">
            <% if (exec.category === 'coordinator') { %><span class="badge badge-gold"><% } else { %><span style="color:var(--gold-dark);font-weight:600;font-size:0.82rem;"><% } %>
              <%= exec.position %>
            <% if (exec.category === 'coordinator') { %></span><% } else { %></span><% } %>
          </div>
          <div class="exec-school"><%= exec.school %></div>
          <% if (exec.bio) { %><p class="exec-bio"><%= exec.bio %></p><% } %>
          <div class="exec-footer">
            <% if (exec.whatsapp) { %>
              <a href="https://wa.me/<%= exec.whatsapp %>" class="btn btn-sm" style="background:#25D366;color:white;border-color:#25D366;" target="_blank">
                <svg width="14" height="14" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                WhatsApp
              </a>
            <% } %>
            <% if (exec.email) { %>
              <a href="mailto:<%= exec.email %>" class="btn btn-sm btn-outline-gold">Email</a>
            <% } %>
          </div>
        </div>
      </div>
      <% }) %>
    </div>

    <% if (isAdmin) { %>
    <div class="info-box" style="margin-top:3rem;">
      <p>🔧 <strong>Admin:</strong> <a href="/admin/executives">Manage executives</a> — add, edit, or remove REC members and school presidents.</p>
    </div>
    <% } %>
  </div>
</section>

<!-- Member Schools -->
<section class="section section-alt">
  <div class="container">
    <div class="section-header">
      <div class="eyebrow">Our Schools</div>
      <h2>Member Institutions</h2>
      <div class="gold-line"></div>
    </div>
    <div class="grid-3">
      <% const schools = [
        { abbr: 'UNN', full: 'University of Nigeria, Nsukka', assoc: 'SUMSA', state: 'Enugu' },
        { abbr: 'ABSU', full: 'Abia State University', assoc: 'MEDSSA', state: 'Abia' },
        { abbr: 'ESUT', full: 'Enugu State University of Science & Technology', assoc: 'SMSAS', state: 'Enugu' },
        { abbr: 'IMSU', full: 'Imo State University', assoc: 'SMSA', state: 'Imo' },
        { abbr: 'UNIZIK', full: 'Nnamdi Azikiwe University', assoc: 'NUMSA', state: 'Anambra' },
        { abbr: 'EBSU', full: 'Ebonyi State University', assoc: 'SMSA', state: 'Ebonyi' }
      ]; %>
      <% schools.forEach(s => { %>
      <div class="card" style="padding:1.5rem;">
        <div style="display:flex;align-items:center;gap:1rem;margin-bottom:1rem;">
          <div style="width:50px;height:50px;border-radius:12px;background:var(--green-light);display:flex;align-items:center;justify-content:center;font-family:var(--font-display);font-weight:800;font-size:0.8rem;color:var(--green-primary);text-align:center;line-height:1.2;"><%= s.abbr %></div>
          <div>
            <div style="font-weight:700;color:var(--green-deep);font-size:0.95rem;"><%= s.assoc %></div>
            <div style="font-size:0.75rem;color:var(--text-muted);"><%= s.state %> State</div>
          </div>
        </div>
        <p style="font-size:0.83rem;color:var(--text-muted);"><%= s.full %></p>
      </div>
      <% }) %>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
<script src="/js/main.js"></script>
</body>
</html>
