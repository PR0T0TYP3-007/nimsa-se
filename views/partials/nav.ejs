<%
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/leadership', label: 'Leadership' },
  { href: '/events', label: 'Events' },
  { href: '/bulletin', label: 'Bulletin' },
  { href: '/resources', label: 'Resources' },
  { href: '/gallery', label: 'Gallery' },
  { href: '/news', label: 'News' },
  { href: '/campaigns', label: 'Campaigns' },
  { href: '/contact', label: 'Contact' },
];
%>
<nav class="navbar" id="navbar">
  <div class="nav-container">
    <!-- Real NiMSA SE Logo -->
    <a href="/" class="nav-logo">
      <img src="/logo.jpg" alt="NiMSA South East Region" class="nav-logo-img">
      <div class="logo-text">
        <span class="logo-nimsa">NiMSA</span>
        <span class="logo-region">South East Region</span>
      </div>
    </a>

    <!-- Desktop Nav Links — NO overflow scroll -->
    <ul class="nav-links" id="nav-links">
      <% navLinks.forEach(link => { %>
        <li>
          <a href="<%= link.href %>" class="nav-link <%= currentPath === link.href ? 'active' : '' %>">
            <%= link.label %>
          </a>
        </li>
      <% }) %>
    </ul>

    <!-- Nav Actions -->
    <div class="nav-actions">
      <% if (user) { %>
        <span class="nav-user">
          <svg width="15" height="15" fill="currentColor" viewBox="0 0 24 24"><path d="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z"/></svg>
          <%= user.name.split(' ')[0] %>
          <% if (isAdmin) { %><span class="admin-badge">Admin</span><% } %>
        </span>
        <% if (isAdmin) { %>
          <a href="/admin" class="btn btn-outline-gold btn-sm">Dashboard</a>
        <% } %>
        <a href="/auth/logout" class="btn btn-sm btn-ghost">Logout</a>
      <% } else { %>
        <a href="/auth/login" class="btn btn-outline-gold btn-sm">Login</a>
        <a href="/join" class="btn btn-gold btn-sm">Join Us</a>
      <% } %>
    </div>

    <!-- Hamburger — always on the far right -->
    <button class="hamburger" id="hamburger" aria-label="Toggle menu" style="margin-left:auto;">
      <span></span><span></span><span></span>
    </button>
  </div>

  <!-- Mobile Menu -->
  <div class="mobile-menu" id="mobile-menu">
    <% if (user) { %>
    <div style="padding:0.8rem 0 0.6rem; border-bottom:1px solid rgba(201,168,76,0.2); margin-bottom:0.4rem; display:flex; align-items:center; gap:0.7rem;">
      <div style="width:34px;height:34px;border-radius:50%;background:rgba(201,168,76,0.15);border:1px solid var(--gold);display:flex;align-items:center;justify-content:center;font-size:0.85rem;font-weight:700;color:var(--gold);flex-shrink:0;">
        <%= user.name.charAt(0) %>
      </div>
      <div>
        <div style="font-size:0.85rem;font-weight:600;color:white;"><%= user.name %></div>
        <div style="font-size:0.7rem;color:rgba(255,255,255,0.5);"><%= user.email %></div>
      </div>
      <% if (isAdmin) { %><span class="admin-badge" style="margin-left:auto;">Admin</span><% } %>
    </div>
    <% } %>

    <% navLinks.forEach(link => { %>
      <a href="<%= link.href %>" class="mobile-link <%= currentPath === link.href ? 'active' : '' %>">
        <%= link.label %>
      </a>
    <% }) %>

    <div class="mobile-actions">
      <% if (user) { %>
        <% if (isAdmin) { %><a href="/admin" class="btn btn-gold btn-block" style="justify-content:center;">⚙ Admin Dashboard</a><% } %>
        <a href="/auth/logout" class="btn btn-outline btn-block" style="justify-content:center;">Logout</a>
      <% } else { %>
        <a href="/auth/login" class="btn btn-outline btn-block" style="justify-content:center;">Login</a>
        <a href="/join" class="btn btn-gold btn-block" style="justify-content:center;">Join NiMSA SE</a>
      <% } %>
    </div>
  </div>
</nav>
