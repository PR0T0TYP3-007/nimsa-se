<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<%- include('partials/nav') %>

<div class="page-hero">
  <div class="container">
    <div class="eyebrow">Who We Are</div>
    <h1>About NiMSA South East Region</h1>
    <p>Founded in 1968. Member of IFMSA. The Most Exceptional Region — uniting 13 medical student associations across five Southeast states.</p>
  </div>
</div>

<!-- WHAT IS NIMSA SE -->
<section class="section">
  <div class="container">
    <div class="about-grid fade-in">
      <div>
        <div class="eyebrow">Our Identity</div>
        <h2 style="margin-bottom:1.2rem;">What is NiMSA South East Region?</h2>
        <p style="margin-bottom:1rem;">
          The <strong>Nigerian Medical Students' Association (NiMSA)</strong>, founded in <strong>1968</strong>, is the official umbrella body for all medical students in Nigeria — recognized as the official student wing of the <strong>Nigerian Medical Association (NMA)</strong>, governed by Act Cap 221 of the Laws of the Federation of Nigeria.
        </p>
        <p style="margin-bottom:1rem;">
          As a full member of the <strong>International Federation of Medical Students' Associations (IFMSA)</strong>, NiMSA connects its regional branches — including the South East — to a global network, providing students access to clinical and research exchanges across the world.
        </p>
        <p style="margin-bottom:1.5rem; color:var(--text-muted);">
          The <strong>NiMSA South East Region</strong> is one of six geopolitical regional branches, governed by the <strong>Regional Coordinator (RC)</strong> — who serves as a bridge between the National Executive Council and the 13 Medical Student Associations (MSAs) across Abia, Anambra, Ebonyi, Enugu, and Imo states.
        </p>
        <div class="info-box">
          <p><strong>Terminology Note:</strong> We are a <em>Region</em>, not a zone. Our governance is led by the <em>Regional Coordinator</em> — not a "president." The RC coordinates and governs the region through the <strong>Regional Executive Council (REC)</strong>, ensuring every member school is represented.</p>
        </div>
      </div>
      <div class="about-img-block">
        <div style="text-align:center;color:white;padding:2rem;">
          <img src="/logo.jpg" alt="NiMSA SE" style="width:100px;height:100px;border-radius:50%;object-fit:cover;border:2px solid var(--gold);margin:0 auto 1rem;">
          <div style="font-size:0.85rem;color:rgba(255,255,255,0.75);font-style:italic;font-family:var(--font-display);font-size:1.1rem;">"Most Exceptional Region"</div>
          <div style="width:40px;height:1px;background:var(--gold);margin:0.8rem auto;"></div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.8rem;margin-top:0.5rem;">
            <% [
              {v:'1968', l:'Founded'},
              {v:'13', l:'MSAs'},
              {v:'5', l:'SE States'},
              {v:'IFMSA', l:'Global Body'}
            ].forEach(s => { %>
            <div style="background:rgba(255,255,255,0.07);border-radius:10px;padding:0.9rem;border:1px solid rgba(201,168,76,0.2);text-align:center;">
              <div style="font-family:var(--font-display);font-size:1.4rem;font-weight:700;color:var(--gold);"><%= s.v %></div>
              <div style="font-size:0.62rem;color:rgba(255,255,255,0.55);text-transform:uppercase;letter-spacing:0.1em;margin-top:2px;"><%= s.l %></div>
            </div>
            <% }) %>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- WHAT WE DO -->
<section class="section section-alt">
  <div class="container">
    <div class="section-header fade-in">
      <div class="eyebrow">Core Functions</div>
      <h2>What We Do</h2>
      <p>NiMSA SE functions as the representative body and developer of medical students across five Southeast states — through advocacy, outreach, academic development, and leadership.</p>
      <div class="gold-line"></div>
    </div>
    <div class="grid-2" style="gap:1.5rem;">
      <% const functions = [
        { icon: '🗣️', title: 'Representation & Advocacy', desc: 'We speak on behalf of Southeast medical students at National Executive Council (NEC) meetings — addressing welfare, academic concerns, and policies. The Regional Coordinator ensures the South East always has a voice at the national level.' },
        { icon: '🏥', title: 'MAK Health Week & Outreach', desc: 'We organise the MAK NiMSA Health Week — named in honour of Mustapha, Aisha, and Kabiru, three medical students lost in a 2023 boat mishap. The inaugural edition was proudly hosted by EBSUMSA in Abakaliki.' },
        { icon: '📚', title: 'Academic & Professional Development', desc: 'Regional conventions, debate tournaments, quiz competitions (including the Dr. Charles Egwuatu Memorial Lecture series), webinars, and workshops prepare students for clinical excellence and public leadership.' },
        { icon: '🌐', title: 'IFMSA Exchange Programmes', desc: 'As part of NiMSA\'s IFMSA membership, Southeast students access international clinical and research exchange programmes — gaining exposure to diverse healthcare systems across Europe, Asia, and the Americas.' },
        { icon: '🏆', title: 'Regional Convention & Awards', desc: 'The annual South East Regional Convention — recently hosted by ESUMSA — is our flagship event featuring academic competitions, the "Face of NiMSA SE" title, leadership elections, and networking across all 13 schools.' },
        { icon: '⚕️', title: 'Social & Health Advocacy', desc: 'Key campaigns include maternal mortality prevention, climate change awareness, sexual and reproductive health outreach for secondary school girls, and the "Medicine and Politics" mentorship programme for future healthcare leaders.' }
      ]; %>
      <% functions.forEach((fn, i) => { %>
      <div class="mission-card fade-in" style="transition-delay:<%= i*0.08 %>s">
        <div class="mission-icon"><%= fn.icon %></div>
        <h3 style="font-size:1rem;margin-bottom:0.6rem;"><%= fn.title %></h3>
        <p style="font-size:0.85rem;color:var(--text-muted);"><%= fn.desc %></p>
      </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- MAK HEALTH WEEK SPOTLIGHT -->
<section class="section">
  <div class="container">
    <div style="background:linear-gradient(140deg,var(--green-deep),var(--green-primary));border-radius:var(--radius-xl);padding:3rem;color:white;border:1px solid rgba(201,168,76,0.2);" class="fade-in">
      <div style="max-width:680px;">
        <div class="eyebrow" style="background:rgba(201,168,76,0.15);border:1px solid rgba(201,168,76,0.4);color:var(--gold);">In Memoriam</div>
        <h2 style="color:white;margin:1rem 0;">The MAK NiMSA Health Week</h2>
        <p style="color:rgba(255,255,255,0.8);margin-bottom:1rem;">
          In 2023, NiMSA lost three of its own — <strong style="color:var(--gold);">Mustapha, Aisha, and Kabiru</strong> — in a tragic boat mishap. To honour their memory and continue their spirit of service, NiMSA's annual Health Week was renamed the <strong>"MAK NiMSA Health Week."</strong>
        </p>
        <p style="color:rgba(255,255,255,0.7);margin-bottom:2rem;">
          The NiMSA South East Region holds the distinction of hosting the <strong>inaugural MAK NiMSA Health Week</strong>, through the Ebonyi State University Medical Students Association (EBSUMSA) in Abakaliki. This reflects our region's resilience, compassion, and central role in the national association's healing process.
        </p>
        <a href="/campaigns" class="btn btn-gold">View Our Campaigns →</a>
      </div>
    </div>
  </div>
</section>

<!-- MEMBER SCHOOLS — ALL 13 from PDF -->
<section class="section section-alt">
  <div class="container">
    <div class="section-header fade-in">
      <div class="eyebrow">Our Schools</div>
      <h2>13 Member Associations</h2>
      <p>All fully accredited by the Medical and Dental Council of Nigeria (MDCN), spanning federal, state, and private institutions across the five Southeast states.</p>
      <div class="gold-line"></div>
    </div>
    <div class="grid-3">
      <%
      const schools = [
        { abbr:'UNMSA',    full:'University of Nigeria (Enugu Campus)',        state:'Enugu',    quota:'150–180',  type:'Federal',  color:'#003d00' },
        { abbr:'NAUMSA',   full:'Nnamdi Azikiwe University, Nnewi',            state:'Anambra',  quota:'100',      type:'Federal',  color:'#1a3a5c' },
        { abbr:'ABSUMSA',  full:'Abia State University, Uturu',                state:'Abia',     quota:'120–150',  type:'State',    color:'#5c1a1a' },
        { abbr:'EBSUMSA',  full:'Ebonyi State University, Abakaliki',          state:'Ebonyi',   quota:'100',      type:'State',    color:'#3a1a5c' },
        { abbr:'ESUMSA',   full:'Enugu State University (ESUT)',                state:'Enugu',    quota:'50',       type:'State',    color:'#1a3d1a' },
        { abbr:'IMSUMSA',  full:'Imo State University, Owerri',                state:'Imo',      quota:'50',       type:'State',    color:'#3d2a1a' },
        { abbr:'COOUMSA',  full:'Chukwuemeka Odumegwu Ojukwu University',      state:'Anambra',  quota:'50',       type:'State',    color:'#1a2a5c' },
        { abbr:'AE-FUMSA', full:'Alex Ekwueme Federal University',              state:'Ebonyi',   quota:'50',       type:'Federal',  color:'#2a3d1a' },
        { abbr:'GOUMSA',   full:'Godfrey Okoye University',                     state:'Enugu',    quota:'—',        type:'Private',  color:'#5c3d1a' },
        { abbr:'GUMSA',    full:'Gregory University, Uturu',                    state:'Abia',     quota:'120',      type:'Private',  color:'#3d1a3d' },
        { abbr:'MUMSA',    full:'Madonna University, Elele/Okija',              state:'Rivers/Anambra', quota:'50', type:'Private', color:'#1a4a3a' },
        { abbr:'UNIZIK Dental', full:'Nnamdi Azikiwe University Dental School', state:'Anambra',  quota:'Dental',   type:'Federal',  color:'#3a2a1a' },
        { abbr:'DUMSA',    full:'David Umahi Federal University',                state:'Ebonyi',   quota:'30',       type:'Federal',  color:'#1a3a3a' }
      ];
      %>
      <% schools.forEach((s, i) => { %>
      <div class="card fade-in" style="padding:0;overflow:hidden;transition-delay:<%= i*0.04 %>s">
        <div style="height:70px;background:linear-gradient(135deg,<%= s.color %>,var(--green-primary));display:flex;align-items:center;justify-content:center;gap:1rem;padding:0 1.2rem;">
          <div style="font-family:var(--font-display);font-size:1.1rem;font-weight:700;color:var(--gold);"><%= s.abbr %></div>
          <span class="badge" style="background:rgba(255,255,255,0.15);color:rgba(255,255,255,0.9);font-size:0.58rem;"><%= s.type %></span>
        </div>
        <div style="padding:1rem 1.2rem;">
          <div style="font-weight:700;color:var(--green-deep);font-size:0.88rem;margin-bottom:0.3rem;"><%= s.full %></div>
          <div style="display:flex;gap:0.5rem;align-items:center;flex-wrap:wrap;">
            <span class="badge badge-green"><%= s.state %></span>
            <% if (s.quota !== '—') { %>
            <span style="font-size:0.72rem;color:var(--text-muted);">Quota: <%= s.quota %></span>
            <% } %>
          </div>
        </div>
      </div>
      <% }) %>
    </div>
    <div class="info-box" style="margin-top:2rem;">
      <p>📋 Accreditation status and training quotas are as approved by the <strong>Medical and Dental Council of Nigeria (MDCN)</strong>. Data sourced from latest available MDCN records. David Umahi Federal University is partially accredited and represents the next wave of regional growth.</p>
    </div>
  </div>
</section>

<!-- LEADERSHIP HISTORY -->
<section class="section">
  <div class="container">
    <div class="section-header fade-in">
      <div class="eyebrow">Our Legacy</div>
      <h2>A Launchpad for National Leadership</h2>
      <p>The South East Region has consistently produced leaders who rise to prominence at the national NiMSA level and beyond.</p>
      <div class="gold-line"></div>
    </div>
    <div class="grid-3">
      <div class="card fade-in" style="padding:1.8rem;">
        <div style="font-size:2rem;margin-bottom:1rem;">🏛️</div>
        <h3 style="font-size:1rem;margin-bottom:0.5rem;">National Leadership Pipeline</h3>
        <p style="font-size:0.83rem;color:var(--text-muted);">Leaders like <strong>Onuorah Webster Jideofor</strong> of NAUMSA rose through Southeast regional participation to become the <strong>45th National President of NiMSA</strong> in 2022 — a testament to the region's leadership development.</p>
      </div>
      <div class="card fade-in" style="padding:1.8rem;transition-delay:0.1s">
        <div style="font-size:2rem;margin-bottom:1rem;">👑</div>
        <h3 style="font-size:1rem;margin-bottom:0.5rem;">Face of NiMSA South East</h3>
        <p style="font-size:0.83rem;color:var(--text-muted);">A formalized tradition of mentorship and succession. The title — most recently handed over from <strong>Precious Faith</strong> (ESUT Parklane) to <strong>Aguigwo Gerald Somtochukwu</strong> of Godfrey Okoye University — celebrates academic excellence, social grace, and advocacy.</p>
      </div>
      <div class="card fade-in" style="padding:1.8rem;transition-delay:0.2s">
        <div style="font-size:2rem;margin-bottom:1rem;">🎓</div>
        <h3 style="font-size:1rem;margin-bottom:0.5rem;">Medicine & Politics</h3>
        <p style="font-size:0.83rem;color:var(--text-muted);">The region runs "Medicine and Politics" mentorship programmes — preparing medical students to be informed leaders in healthcare administration, policy, and governance, not just clinicians.</p>
      </div>
    </div>
  </div>
</section>

<!-- CTA -->
<section style="background:linear-gradient(155deg,var(--green-deep),var(--green-primary));padding:5rem 0;text-align:center;">
  <div class="container">
    <h2 style="color:white;margin-bottom:1rem;">Join the Most Exceptional Region</h2>
    <p style="color:rgba(255,255,255,0.75);max-width:480px;margin:0 auto 2rem;">Be part of a legacy of excellence, advocacy, and compassionate service to the Southeast and beyond.</p>
    <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
      <a href="/join" class="btn btn-gold btn-lg">Join NiMSA SE</a>
      <a href="/leadership" class="btn btn-outline btn-lg" style="color:white;border-color:rgba(255,255,255,0.4);">Meet Our Leaders</a>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
<script src="/js/main.js"></script>
</body>
</html>
