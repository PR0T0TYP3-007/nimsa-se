<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .gallery-grid { columns: 3; gap: 1rem; }
    @media (max-width:768px) { .gallery-grid { columns: 2; } }
    @media (max-width:480px) { .gallery-grid { columns: 1; } }
    .gallery-item { break-inside: avoid; margin-bottom: 1rem; border-radius: 10px; overflow: hidden; position: relative; cursor: pointer; }
    .gallery-item:hover .gallery-overlay { opacity: 1; }
    .gallery-overlay { position:absolute;inset:0;background:rgba(0,100,0,0.7);opacity:0;transition:all 0.3s ease;display:flex;align-items:center;justify-content:center;color:white;font-size:0.85rem;font-weight:600; }
    .gallery-placeholder { display:flex;flex-direction:column;align-items:center;justify-content:center;color:rgba(255,255,255,0.7);font-size:0.82rem;text-align:center;padding:1.5rem; }
  </style>
</head>
<body>
<%- include('partials/nav') %>

<div class="page-hero">
  <div class="container">
    <div class="eyebrow">Gallery</div>
    <h1>Moments & Memories</h1>
    <p>A visual record of NiMSA SE's conventions, outreaches, webinars, and campus activities across the region.</p>
  </div>
</div>

<section class="section">
  <div class="container">
    <!-- Filter Tabs -->
    <div class="tabs" style="max-width:700px; margin: 0 auto 3rem;" id="gallery-filter">
      <button class="tab-btn active" data-cat="all" onclick="filterGallery('all')">All Photos</button>
      <button class="tab-btn" data-cat="convention" onclick="filterGallery('convention')">Conventions</button>
      <button class="tab-btn" data-cat="webinar" onclick="filterGallery('webinar')">Webinars</button>
      <button class="tab-btn" data-cat="campaign" onclick="filterGallery('campaign')">Campaigns</button>
      <button class="tab-btn" data-cat="campus" onclick="filterGallery('campus')">Campus Life</button>
    </div>

    <div class="gallery-grid" id="gallery-grid">
      <%
      const placeholders = [
        { cat: 'convention', label: 'Annual Regional Convention', color: 'linear-gradient(135deg,#006400,#003300)', h: 260 },
        { cat: 'campaign', label: 'Hypertension Screening — Enugu', color: 'linear-gradient(135deg,#1a5c1a,#006400)', h: 180 },
        { cat: 'webinar', label: 'Clinical Skills Webinar', color: 'linear-gradient(135deg,#003300,#006400)', h: 200 },
        { cat: 'campus', label: 'UNN SUMSA Chapter Meeting', color: 'linear-gradient(135deg,#004d00,#1a5c1a)', h: 220 },
        { cat: 'convention', label: 'Award Night — Most Exceptional Region', color: 'linear-gradient(135deg,#b8941f,#d4af37)', h: 180 },
        { cat: 'campaign', label: 'Malaria Prevention Drive — Imo', color: 'linear-gradient(135deg,#006400,#004d00)', h: 240 },
        { cat: 'campus', label: 'New Executives Swearing-In', color: 'linear-gradient(135deg,#003300,#1a5c1a)', h: 190 },
        { cat: 'webinar', label: 'Research Methodology Workshop', color: 'linear-gradient(135deg,#1a3a5c,#1565c0)', h: 210 },
        { cat: 'convention', label: 'Cultural Night — Convention 2025', color: 'linear-gradient(135deg,#5c1a1a,#c62828)', h: 170 },
        { cat: 'campaign', label: 'Free Blood Pressure Check — Ebonyi', color: 'linear-gradient(135deg,#006400,#003d00)', h: 195 },
        { cat: 'campus', label: 'MEDSSA Abia State Chapter', color: 'linear-gradient(135deg,#3a1a5c,#6a1b9a)', h: 230 },
        { cat: 'webinar', label: 'IFMSA Exchange Info Session', color: 'linear-gradient(135deg,#00695c,#004d40)', h: 200 }
      ];
      %>
      <% placeholders.forEach((p, i) => { %>
      <div class="gallery-item" data-cat="<%= p.cat %>"
           style="background:<%= p.color %>; height:<%= p.h %>px;"
           onclick="openLightbox('<%= p.label %>')">
        <div class="gallery-placeholder">
          <svg width="36" height="36" fill="rgba(255,255,255,0.3)" viewBox="0 0 24 24"><path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/></svg>
          <span style="margin-top:0.5rem;"><%= p.label %></span>
        </div>
        <div class="gallery-overlay">🔍 View Photo</div>
      </div>
      <% }) %>
    </div>

    <div class="info-box" style="margin-top:3rem;">
      <p>📸 Want to contribute photos? Send your event photos to <a href="mailto:<%= settings.email %>"><%= settings.email %></a> or WhatsApp the PRO directly.</p>
    </div>

    <% if (isAdmin) { %>
    <div class="info-box" style="border-left-color:var(--green-primary);">
      <p>🔧 <strong>Admin:</strong> Gallery photo management (upload/delete) coming in the next update. For now, photos can be submitted via email to the ICT Directorate.</p>
    </div>
    <% } %>
  </div>
</section>

<!-- Lightbox -->
<div id="lightbox" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.9);z-index:9999;align-items:center;justify-content:center;flex-direction:column;">
  <button onclick="closeLightbox()" style="position:absolute;top:1.5rem;right:1.5rem;background:none;border:none;color:white;font-size:2rem;cursor:pointer;">✕</button>
  <div id="lightbox-caption" style="color:var(--gold);font-family:var(--font-display);font-size:1.2rem;text-align:center;padding:2rem;"></div>
</div>

<%- include('partials/footer') %>
<script src="/js/main.js"></script>
<script>
function filterGallery(cat) {
  document.querySelectorAll('#gallery-filter .tab-btn').forEach(b => b.classList.remove('active'));
  event.target.classList.add('active');
  document.querySelectorAll('.gallery-item').forEach(item => {
    item.style.display = (cat === 'all' || item.dataset.cat === cat) ? 'block' : 'none';
  });
}
function openLightbox(caption) {
  const lb = document.getElementById('lightbox');
  document.getElementById('lightbox-caption').textContent = caption;
  lb.style.display = 'flex';
}
function closeLightbox() {
  document.getElementById('lightbox').style.display = 'none';
}
document.getElementById('lightbox').addEventListener('click', function(e) {
  if (e.target === this) closeLightbox();
});
</script>
</body>
</html>
